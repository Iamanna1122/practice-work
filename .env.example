# ==========================================
# 機器人環境變數範例檔
# 請將此檔案複製一份並重新命名為 .env
# 然後填寫您的 API Keys
# ==========================================

# 1. Google Gemini API 密鑰 (前往 Google AI Studio 免費申請)
GEMINI_API_KEY="your_gemini_api_key_here"

# 2. Telegram Bot Token (在 Telegram 中搜尋 @BotFather 取得)
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"
# Telegram Chat ID (對你的機器人傳送訊息後，透過 API 取得)
TELEGRAM_CHAT_ID="your_telegram_chat_id_here"

# 3. LINE Messaging API Token (從 LINE Developers Console 取得)
# 提醒：LINE Notify 即將停用，因此我們改用 LINE Messaging API 的 Push 訊息功能
LINE_CHANNEL_ACCESS_TOKEN="your_line_channel_access_token_here"
# LINE User ID (從 LINE Developers Console 的 Basic Settings 取得)
LINE_USER_ID="your_line_user_id_here"
